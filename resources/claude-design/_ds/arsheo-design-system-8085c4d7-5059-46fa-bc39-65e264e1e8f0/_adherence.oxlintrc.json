{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/backlog/**",
              "components/badges/**",
              "components/buttons/**",
              "components/cards/**",
              "components/forms/**",
              "components/glass/**",
              "components/navbar/**",
              "components/pricing/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Hanken Grotesk|JetBrains Mono|Caveat))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Hanken Grotesk, JetBrains Mono, Caveat."
      },
      {
        "selector": "JSXOpeningElement[name.name='BacklogItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|cat|status|key|ref|className|style|children)$/]",
        "message": "<BacklogItem> doesn't accept that prop. Declared props: label, cat, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='BacklogItem'] > JSXAttribute[name.name='cat'] > Literal[value!=/^(?:dette|bug|securite|version|tests)$/]",
        "message": "<BacklogItem> cat must be one of 'dette' | 'bug' | 'securite' | 'version' | 'tests'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BacklogItem'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:done|active|queued)$/]",
        "message": "<BacklogItem> status must be one of 'done' | 'active' | 'queued'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, icon, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|terracotta|honey|success|eu|solid)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'terracotta' | 'honey' | 'success' | 'eu' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|eyebrow|title|icon|interactive|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, eyebrow, title, icon, interactive, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|style|key|ref|className|style|children)$/]",
        "message": "<GlassPanel> doesn't accept that prop. Declared props: children, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|type|placeholder|icon|id|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, type, placeholder, icon, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|glass|cta|key|ref|className|style|children)$/]",
        "message": "<Navbar> doesn't accept that prop. Declared props: links, glass, cta."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|eyebrow|price|period|tagline|features|cta|note|featured|key|ref|className|style|children)$/]",
        "message": "<PricingCard> doesn't accept that prop. Declared props: name, eyebrow, price, period, tagline, features, cta, note, featured."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
